<!-- Кореневий опис моду для Bannerlord Launcher -->
<Module>
  <!-- Відображувана назва моду у лаунчері -->
  <Name value="Coop Spectator" />
  <!-- Унікальний Id моду (використовується як папка моду) -->
  <Id value="CoopSpectator" />
  <!-- Версія моду (для релізів/сумісності) -->
  <Version value="v0.1.1" />
  <!-- Прапорець що мод працює у сингплеєрі (кампанія) -->
  <SingleplayerModule value="true" />
  <!-- true = мод показується в списку модів для мультиплеєру (клієнт з патчем localhost) -->
  <MultiplayerModule value="true" />
  <!-- Тільки Native + Multiplayer — щоб лаунчер показував мод у вкладці мультиплеєр (там немає StoryMode/Sandbox). У кампанії ці модулі все одно завантажуються раніше. -->
  <DependedModules>
    <DependedModule Id="Native" />
    <DependedModule Id="Multiplayer" />
  </DependedModules>
  <!-- Підмодулі (C# DLL), які завантажує гра -->
  <SubModules>
    <SubModule>
      <!-- Назва підмодуля (для відображення/логів) -->
      <Name value="CoopSpectator" />
      <!-- Ім'я DLL, яку завантажує гра (лежить у bin/Win64_Shipping_Client/) -->
      <DLLName value="CoopSpectator.dll" />
      <!-- Повне ім'я класу-ентріпойнта, який наслідує MBSubModuleBase -->
      <SubModuleClassType value="CoopSpectator.SubModule" />
      <!-- Теги для dedicated server (ми не використовуємо) -->
      <Tags>
        <Tag key="DedicatedServerType" value="none" />
      </Tags>
    </SubModule>
  </SubModules>
  <Xmls>
    <XmlNode>
      <XmlName id="Items" path="coopspectator_items" />
      <IncludedGameTypes>
        <GameType value="MultiplayerGame" />
      </IncludedGameTypes>
    </XmlNode>
    <XmlNode>
      <XmlName id="MPCharacters" path="coopspectator_mpcharacters" />
      <IncludedGameTypes>
        <GameType value="MultiplayerGame" />
      </IncludedGameTypes>
    </XmlNode>
    <XmlNode>
      <XmlName id="MPClassDivisions" path="coopspectator_mpclassdivisions" />
      <IncludedGameTypes>
        <GameType value="MultiplayerGame" />
      </IncludedGameTypes>
    </XmlNode>
    <XmlNode>
      <XmlName id="GameText" path="multiplayer_strings" />
      <IncludedGameTypes>
        <GameType value="MultiplayerGame" />
      </IncludedGameTypes>
    </XmlNode>
  </Xmls>
</Module>

